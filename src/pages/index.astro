---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Band {
	bandName: string;
	bandNameTitleCase: string;
	bandNameSlug: string;
	pdfPath: string;
	exampleLink: string;
	hometown: string;
	genre: string[];
	contactEmailAddress: string;
}

const bandsData = await import('../data/lineup.json');
const bands: Band[] = bandsData.default;

const getLinkLabel = (url: string): string => {
	if (url.includes('youtube.com') || url.includes('youtu.be')) return 'Video';
	if (url.includes('spotify.com')) return 'Spotify';
	if (url.includes('bandcamp.com')) return 'Bandcamp';
	if (url.includes('soundcloud.com')) return 'SoundCloud';
	if (url.includes('dropbox.com')) return 'Dropbox';
	return 'Website';
};
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Das Indoor-Metal-Festival in Südwest-Deutschland" />
		<title>Schlacht um Otzenhausen 2026</title>
	</head>
	<body>
		<header class="aspect-video bg-gray-800 flex items-center justify-center text-center py-16">
			<div class="max-w-5xl mx-auto px-4">
				<h1 class="text-xl sm:text-2xl md:text-4xl">
					<img class="w-full h-auto" src="/logo.png" alt="" />
					<span class="sr-only">Schlacht um Otzenhausen</span>
					<span>07.11.2026 – Hunnenringhalle Otzenhausen</span>
				</h1>
				<div class="flex justify-center mt-6 space-x-2 space-y-4 sm:space-y-0 sm:space-x-4">
					<a
						target="_blank"
						href="https://maps.app.goo.gl/pAmF46bb6ifJRdzM8"
						class="px-4 py-2 duration-100 text-center inline-block focus-visible:ring-4 focus-visible:ring-red-400 focus-visible:outline-none active:scale-[98%] rounded-md bg-gray-700 text-red-50 hover:bg-gray-600 active:bg-gray-500 w-full sm:text-xl sm:w-48"
					>
						Anfahrt
					</a>
				</div>
			</div>
		</header>

		<main class="max-w-5xl mx-auto px-4 py-16">
			<div role="list" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
				{
					bands.map((band) => (
						<div role="listitem" class="bg-gray-800 overflow-hidden rounded-lg shadow-md flex flex-col">
							<img
								src={`https://via.placeholder.com/400x300?text=${encodeURIComponent(band.bandName)}`}
								alt={band.bandName}
								class="aspect-video object-cover object-center"
							/>
							<div class="flex flex-col items-start justify-start flex-1 p-4">
								<header class="flex flex-col leading-normal">
									<h2 class="text-lg font-semibold md:text-xl">{band.bandNameTitleCase}</h2>
									<p class="text-gray-400">
										<span class="sr-only">Genre:</span>
										{band.genre.join(', ')}
									</p>
								</header>
								{band.exampleLink && (
									<div class="mt-4 w-full">
										<a
											href={band.exampleLink}
											target="_blank"
											rel="noopener noreferrer"
											class="px-3 py-2 duration-100 text-center inline-block focus-visible:ring-4 focus-visible:ring-red-400 focus-visible:outline-none active:scale-[98%] rounded-md border border-red-900 text-red-50 hover:bg-red-900/20 active:bg-red-900/30 w-full text-sm md:text-base"
										>
											{getLinkLabel(band.exampleLink)} - Reinhören
										</a>
									</div>
								)}
							</div>
						</div>
					))
				}
			</div>
		</main>

		<footer class="bg-gray-800 py-8">
			<div class="max-w-5xl mx-auto px-4 flex justify-between">
				<span>© 2026 Celtic Warriors Otzenhausen e.V.</span>
				<a href="https://cwo-ev.de/impressum/">Impressum</a>
			</div>
		</footer>
	</body>
</html>
